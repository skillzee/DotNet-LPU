@model MvcAssessmentTopBrains.ViewModels.StudentProfileViewModel

@{
    ViewData["Title"] = "Student Dashboard";
}

<h2>Student Dashboard</h2>

@if (Model != null)
{
    <h3>Profile Information</h3>
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.StudentName</dd>
        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Email</dd>
        <dt class="col-sm-2">Phone Number</dt>
        <dd class="col-sm-10">@Model.PhoneNumber</dd>
        <dt class="col-sm-2">Address</dt>
        <dd class="col-sm-10">@Model.Address</dd>
        <dt class="col-sm-2">Department</dt>
        <dd class="col-sm-10">@Model.DepartmentName</dd>
        <dt class="col-sm-2">Course</dt>
        <dd class="col-sm-10">@Model.CourseName</dd>
    </dl>

    <h3>Course Details</h3>
    <dl class="row">
        <dt class="col-sm-2">Course Name</dt>
        <dd class="col-sm-10">@Model.CourseName</dd>
        <dt class="col-sm-2">Duration</dt>
        <dd class="col-sm-10">@Model.CourseDuration</dd>
        <dt class="col-sm-2">Fees</dt>
        <dd class="col-sm-10">@Model.CourseFees</dd>
        <dt class="col-sm-2">Department</dt>
        <dd class="col-sm-10">@Model.DepartmentName</dd>
    </dl>

    <a asp-action="Profile" class="btn btn-primary">Update Profile</a>
}
else
{
    <p>@ViewBag.Message</p>
}

<a asp-action="Logout" asp-controller="Account" class="btn btn-danger">Logout</a>